# =====================================================================
# Kairos frontend — variables de entorno
#
# Vite carga estos archivos automáticamente:
#   .env                    — todos los entornos (committeable)
#   .env.development        — solo `npm run dev` (committeable, hoy tiene
#                             localhost:3333 + Cloudinary)
#   .env.production         — solo `npm run build` (NO committear; en CF
#                             Pages se setean desde el panel de env vars)
#   .env.*.local            — overrides locales por entorno (gitignored
#                             via "*.local" en .gitignore)
#
# Las VITE_* quedan EMBEBIDAS en el bundle JS, accesibles desde el
# browser. NUNCA pongas acá secretos (API keys privadas, tokens, etc.).
# Las que tenemos abajo son TODAS públicas a propósito.
# =====================================================================

# URL pública del backend. Incluye /api/v1 al final.
# Dev local:        http://localhost:3333/api/v1
# [PROD] Oracle:    https://api.kairos.app/api/v1  (o el dominio que uses)
VITE_API_BASE_URL=http://localhost:3333/api/v1

# Cloudinary unsigned upload — ambos valores son públicos por diseño
# (el preset está marcado "unsigned" en Cloudinary, restringido por
# folder y formato). Si rotás el preset, actualizar acá y en CF Pages.
VITE_CLOUDINARY_CLOUD_NAME=ddi0npc6d
VITE_CLOUDINARY_UPLOAD_PRESET=reviewhub_covers
